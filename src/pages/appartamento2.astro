---
// ============================================================
//  appartamento2.astro — layout della pagina Appartamento 2
//
//  Testi e dati  →  src/content/appartamento2.ts
//  Stile shared  →  src/styles/appartamento-shared.css
//  Stile hero    →  src/styles/appartamento2.css
//  Script        →  src/scripts/appartamento.ts
// ============================================================

import Layout from '../layouts/Layout.astro';
import { appartamento2 as apt } from '../content/appartamento2';
import { fascePrezzi } from '../content/prezzi';

import '../styles/appartamento2.css';

const ospitiFull = Object.keys(apt.prezzi).map(Number).sort((a, b) => a - b);
const prezziJson = JSON.stringify(apt.prezzi);
const fasceJson  = JSON.stringify(fascePrezzi);
---

<Layout title={apt.seo_title} description={apt.seo_description}>

  <!-- HERO -->
  <section class="apt-hero">
    <div class="apt-hero-bg"></div>
    <div class="apt-hero-content">
      <span class="eyebrow fade-in">{apt.eyebrow}</span>
      <h1 class="fade-in">{apt.nome}</h1>
      <p class="fade-in">{apt.caratteristiche}</p>
    </div>
  </section>

  <section class="section">
    <div class="container apt-layout">

      <!-- COLONNA PRINCIPALE -->
      <div class="apt-main">

        <!-- Descrizione -->
        <div class="apt-desc">
          <span class="eyebrow">{apt.sezione_eyebrow}</span>
          <h2>{apt.sezione_titolo}</h2>
          <div class="divider" style="margin-left:0"></div>
          <p>{apt.descrizione_1}</p>
          <p style="margin-top:1rem">{apt.descrizione_2}</p>
        </div>

        <!-- Galleria -->
        <div class="gallery" id="gallery" data-foto={JSON.stringify(apt.foto)}>
          <div class="gallery-main-wrap">
            <button class="gallery-arrow arrow-prev" id="arrow-prev" aria-label="Foto precedente">&#8592;</button>
            <div class="gallery-main">
              {apt.foto[0] ? (
                <img
                  src={apt.foto[0].src}
                  alt={apt.foto[0].alt}
                  class="gallery-img"
                  id="foto-principale"
                />
              ) : (
                <div class="img-placeholder">
                  <span>📷 Aggiungi foto in src/content/appartamento2.ts</span>
                </div>
              )}
            </div>
            <button class="gallery-arrow arrow-next" id="arrow-next" aria-label="Foto successiva">&#8594;</button>
          </div>

          <div class="gallery-meta">
            <span class="gallery-alt" id="gallery-alt">{apt.foto[0]?.alt ?? ''}</span>
            <span class="gallery-count" id="gallery-count">1 / {apt.foto.length}</span>
          </div>

          {apt.foto.length > 1 && (
            <div class="gallery-grid">
              {apt.foto.map((foto, i) => (
                <button
                  class={`gallery-thumb${i === 0 ? ' attiva' : ''}`}
                  data-index={i}
                  aria-label={`Mostra: ${foto.alt}`}
                >
                  <img src={foto.src} alt={foto.alt} class="thumb-img" />
                </button>
              ))}
            </div>
          )}
        </div>

        <!-- Dotazioni -->
        <div class="apt-section">
          <h3>Dotazioni</h3>
          <ul class="dotazioni-grid">
            {apt.dotazioni.map(d => (
              <li><span class="check">✓</span>{d}</li>
            ))}
          </ul>
        </div>

        <!-- Regole -->
        <div class="apt-section">
          <h3>Regole della casa</h3>
          <ul class="regole-list">
            {apt.regole.map(r => <li>{r}</li>)}
          </ul>
        </div>

      </div>

      <!-- SIDEBAR PREZZI -->
      <aside class="apt-sidebar">
        <div
          class="price-card"
          data-prezzi={prezziJson}
          data-fasce={fasceJson}
          id="price-card"
        >
          <h3>Prezzi per notte</h3>
          <div class="divider" style="margin: 1rem 0;"></div>

          <!-- Selettore ospiti -->
          <div class="ospiti-selector">
            <p class="ospiti-label">Numero di ospiti</p>
            <div class="ospiti-btns" id="ospiti-btns">
              {ospitiFull.map((n, i) => (
                <button
                  class={`ospiti-btn${i === 0 ? ' attivo' : ''}`}
                  data-ospiti={n}
                  aria-label={`${n} ${n === 1 ? 'ospite' : 'ospiti'}`}
                >
                  {n}
                </button>
              ))}
            </div>
          </div>

          <div class="price-separator"></div>

          <!-- Tabella prezzi — popolata dallo script -->
          <div id="price-rows"></div>

          <div class="price-separator"></div>
          <p class="price-note">* {apt.prezzi_nota}</p>

          <a
            href="/contatti"
            class="btn btn-primary"
            style="width:100%; text-align:center; margin-top:1.5rem; display:block;"
          >
            Richiedi disponibilità
          </a>
        </div>
      </aside>

    </div>
  </section>

</Layout>

<script src="../scripts/appartamento.ts"></script>
