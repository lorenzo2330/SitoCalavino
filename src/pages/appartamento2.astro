---
import Layout from '../layouts/Layout.astro';
import { appartamento2 as apt } from '../content/appartamento2';
---
<Layout title={apt.seo_title} description={apt.seo_description}>

  <section class="apt-hero">
    <div class="apt-hero-bg"></div>
    <div class="apt-hero-content">
      <span class="eyebrow fade-in">{apt.eyebrow}</span>
      <h1 class="fade-in">{apt.nome}</h1>
      <p class="fade-in">{apt.caratteristiche}</p>
    </div>
  </section>

  <section class="section">
    <div class="container apt-layout">

      <div class="apt-main">
        <div class="apt-desc">
          <span class="eyebrow">{apt.sezione_eyebrow}</span>
          <h2>{apt.sezione_titolo}</h2>
          <div class="divider" style="margin-left:0"></div>
          <p>{apt.descrizione_1}</p>
          <p style="margin-top:1rem">{apt.descrizione_2}</p>
        </div>

        <!-- GALLERIA con frecce + didascalia -->
        <div class="gallery" id="gallery" data-foto={JSON.stringify(apt.foto)}>
          <div class="gallery-main-wrap">
            <button class="gallery-arrow arrow-prev" id="arrow-prev" aria-label="Foto precedente">&#8592;</button>
            <div class="gallery-main">
              {apt.foto[0] ? (
                <img src={apt.foto[0].src} alt={apt.foto[0].alt} class="gallery-img" id="foto-principale" />
              ) : (
                <div class="img-placeholder"><span>📷 Aggiungi foto in src/content/appartamento2.ts</span></div>
              )}
            </div>
            <button class="gallery-arrow arrow-next" id="arrow-next" aria-label="Foto successiva">&#8594;</button>
          </div>

          <!-- didascalia + contatore -->
          <div class="gallery-meta">
            <span class="gallery-alt" id="gallery-alt">{apt.foto[0]?.alt ?? ""}</span>
            <span class="gallery-count" id="gallery-count">1 / {apt.foto.length}</span>
          </div>

          <!-- miniature -->
          {apt.foto.length > 1 && (
            <div class="gallery-grid" id="gallery-grid">
              {apt.foto.map((foto, i) => (
                <button
                  class={`gallery-thumb${i === 0 ? " attiva" : ""}`}
                  data-index={i}
                  aria-label={`Mostra: ${foto.alt}`}
                >
                  <img src={foto.src} alt={foto.alt} class="thumb-img" />
                </button>
              ))}
            </div>
          )}
        </div>

        <div class="apt-section">
          <h3>Dotazioni</h3>
          <ul class="dotazioni-grid">
            {apt.dotazioni.map(d => (
              <li><span class="check">✓</span>{d}</li>
            ))}
          </ul>
        </div>

        <div class="apt-section">
          <h3>Regole della casa</h3>
          <ul class="regole-list">
            {apt.regole.map(r => <li>{r}</li>)}
          </ul>
        </div>
      </div>

      <aside class="apt-sidebar">
        <div class="price-card">
          <h3>Prezzi per notte</h3>
          <div class="divider" style="margin: 1rem 0;"></div>
          <div class="price-row"><span>Feriale</span><strong>€{apt.prezzi.feriale}</strong></div>
          <div class="price-row"><span>Festivo</span><strong>€{apt.prezzi.festivo}</strong></div>
          <div class="price-separator"></div>
          <p class="price-label">Alta stagione<br/><small>({apt.prezzi.alta_stagione_mesi.join(", ")})</small></p>
          <div class="price-row"><span>Feriale & Festivo</span><strong>€{apt.prezzi.alta_stagione}</strong></div>
          <div class="price-row"><span>Combo 5 notti</span><strong>€{apt.prezzi.alta_stagione_cinque_notti}</strong></div>
          <div class="price-row"><span>Combo 6 notti</span><strong>€{apt.prezzi.alta_stagione_sei_notti}</strong></div>
          <div class="price-separator"></div>
          <p class="price-note">* {apt.prezzi.nota}</p>
          <a href="/contatti" class="btn btn-primary" style="width:100%; text-align:center; margin-top:1.5rem; display:block;">
            Richiedi disponibilità
          </a>
        </div>
      </aside>

    </div>
  </section>

</Layout>

<style>
  .apt-hero { position: relative; height: 65vh; min-height: 400px; display: flex; align-items: flex-end; overflow: hidden; }
  .apt-hero-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgba(28,28,28,0.85) 0%, rgba(44,62,45,0.3) 60%, transparent 100%),
      url('/foto/appartamento2/cucina1-duplex.jpeg') center/cover no-repeat;
  }
  .apt-hero-content { position: relative; z-index: 2; padding: 3rem; color: var(--cream); }
  .apt-hero-content .eyebrow { color: var(--gold-light); }
  .apt-hero-content h1 { font-size: clamp(2.5rem, 6vw, 4.5rem); color: var(--cream); margin-bottom: 0.5rem; }
  .apt-hero-content p { color: rgba(245,240,232,0.75); font-size: 0.9rem; letter-spacing: 0.1em; }

  .apt-layout { display: grid; grid-template-columns: 1fr 340px; gap: 4rem; align-items: start; }
  .apt-desc h2 { font-size: 2.2rem; color: var(--deep-wood); margin-bottom: 0.5rem; }
  .apt-desc p { color: var(--text-light); line-height: 1.9; }

  /* ── GALLERIA ── */
  .gallery { margin: 3rem 0; }

  .gallery-main-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .gallery-main {
    flex: 1;
    height: 420px;
    overflow: hidden;
    background: var(--cream);
    border: 2px solid var(--stone);
    padding: 8px;
    box-shadow: 0 4px 20px rgba(74,55,40,0.12);
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: var(--cream);
    transition: opacity 0.25s ease;
    display: block;
  }

  .gallery-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(253,250,244,0.92);
    border: 1px solid var(--stone);
    color: var(--bark);
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 50%;
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    box-shadow: 0 2px 8px rgba(74,55,40,0.15);
  }
  .gallery-arrow:hover { background: var(--bark); color: var(--cream); border-color: var(--bark); }
  .arrow-prev { left: 0.6rem; }
  .arrow-next { right: 0.6rem; }

  .gallery-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.5rem;
    padding: 0 0.2rem;
  }
  .gallery-alt { font-size: 0.82rem; color: var(--text-light); font-style: italic; letter-spacing: 0.03em; }
  .gallery-count { font-size: 0.75rem; color: var(--text-light); letter-spacing: 0.08em; }

  .gallery-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 0.6rem; margin-top: 0.75rem; }
  .gallery-thumb { border: 2px solid var(--stone); padding: 3px; cursor: pointer; overflow: hidden; height: 80px; background: var(--cream); border-radius: var(--radius); transition: border-color 0.2s, transform 0.2s; }
  .gallery-thumb:hover { transform: scale(1.03); border-color: var(--bark); }
  .gallery-thumb.attiva { border-color: var(--gold); box-shadow: 0 0 0 1px var(--gold); }
  .thumb-img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .img-placeholder { width: 100%; height: 100%; background: var(--cream); border: 2px dashed var(--stone); display: flex; align-items: center; justify-content: center; color: var(--text-light); font-size: 0.85rem; text-align: center; padding: 1rem; }

  .apt-section { margin-top: 3rem; }
  .apt-section h3 { font-family: var(--font-display); font-size: 1.6rem; color: var(--deep-wood); margin-bottom: 1.2rem; padding-bottom: 0.7rem; border-bottom: 1px solid var(--stone); }
  .dotazioni-grid { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem 1.5rem; }
  .dotazioni-grid li { display: flex; align-items: center; gap: 0.6rem; font-size: 0.9rem; color: var(--text-light); }
  .check { color: var(--gold); font-weight: bold; }
  .regole-list { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
  .regole-list li { font-size: 0.9rem; color: var(--text-light); padding-left: 1rem; border-left: 2px solid var(--stone); }

  .price-card { background: var(--cream); padding: 2rem; position: sticky; top: 100px; border-top: 3px solid var(--gold); }
  .price-card h3 { font-family: var(--font-display); font-size: 1.5rem; color: var(--deep-wood); }
  .price-row { display: flex; justify-content: space-between; align-items: center; padding: 0.6rem 0; font-size: 0.95rem; color: var(--text-light); }
  .price-row strong { font-family: var(--font-display); font-size: 1.4rem; color: var(--deep-wood); font-weight: 600; }
  .price-separator { height: 1px; background: var(--stone); margin: 1rem 0; opacity: 0.4; }
  .price-label { font-size: 0.8rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--bark); margin-bottom: 0.5rem; }
  .price-label small { text-transform: none; letter-spacing: 0; font-weight: 300; }
  .price-note { font-size: 0.75rem; color: var(--text-light); line-height: 1.6; }

  @media (max-width: 900px) {
    .apt-layout { grid-template-columns: 1fr; }
    .apt-sidebar { order: -1; }
    .price-card { position: static; }
    .dotazioni-grid { grid-template-columns: 1fr; }
    .gallery-grid { grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); }
    .gallery-main { height: 280px; }
  }
</style>

<script>
  const foto = JSON.parse(document.getElementById('gallery')!.dataset.foto!);

  const imgPrincipale = document.getElementById('foto-principale') as HTMLImageElement;
  const altEl         = document.getElementById('gallery-alt') as HTMLElement;
  const countEl       = document.getElementById('gallery-count') as HTMLElement;
  const thumbs        = document.querySelectorAll<HTMLButtonElement>('.gallery-thumb');
  const btnPrev       = document.getElementById('arrow-prev') as HTMLButtonElement;
  const btnNext       = document.getElementById('arrow-next') as HTMLButtonElement;
  const totale        = foto.length;
  let corrente        = 0;

  function vai(indice: number) {
    corrente = (indice + totale) % totale;

    imgPrincipale.style.opacity = '0';
    setTimeout(() => {
      imgPrincipale.src = foto[corrente].src;
      imgPrincipale.alt = foto[corrente].alt;
      imgPrincipale.style.opacity = '1';
    }, 200);

    altEl.textContent   = foto[corrente].alt;
    countEl.textContent = `${corrente + 1} / ${totale}`;

    thumbs.forEach((t, i) => t.classList.toggle('attiva', i === corrente));
    thumbs[corrente]?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
  }

  thumbs.forEach((thumb, i) => thumb.addEventListener('click', () => vai(i)));
  btnPrev.addEventListener('click', () => vai(corrente - 1));
  btnNext.addEventListener('click', () => vai(corrente + 1));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft')  vai(corrente - 1);
    if (e.key === 'ArrowRight') vai(corrente + 1);
  });
</script>
