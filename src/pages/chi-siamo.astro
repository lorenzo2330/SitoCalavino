---
// ============================================================
//  chi-siamo.astro — pagina Chi siamo
//
//  Testi e dati  →  src/content/chi-siamo.ts
//  Stile         →  src/styles/chi-siamo.css
// ============================================================

import Layout from '../layouts/Layout.astro';
import { chiSiamo as p } from '../content/chi-siamo';

import '../styles/chi-siamo.css';
---

<Layout title={p.seo_title} description={p.seo_description}>

  <!-- HERO -->
  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-content">
      <span class="eyebrow fade-in">{p.hero_eyebrow}</span>
      <h1 class="fade-in">{p.hero_titolo}</h1>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section text-center">
    <div class="container intro-wrap">
      <span class="eyebrow">{p.intro_eyebrow}</span>
      <h2 class="intro-titolo">{p.intro_titolo}</h2>
      <div class="divider"></div>
      <p class="intro-testo">{p.intro_testo}</p>
    </div>
  </section>

  <!-- FOTO CENTRALE -->
  <!--
  <section class="foto-centrale-section">
    <div class="container">
      <div class="foto-centrale-wrap">
        <img
          src={p.foto_centrale.src}
          alt={p.foto_centrale.alt}
          class="foto-centrale-img"
        />
      </div>
    </div>
  </section>
   -->


  <!-- CTA -->
  <section class="section text-center cta-section">
    <div class="container">
      <span class="eyebrow">{p.cta_eyebrow}</span>
      <h2 class="cta-titolo">{p.cta_titolo}</h2>
      <div class="divider"></div>
      <p class="cta-testo">{p.cta_testo}</p>
      <a href="/contatti" class="btn btn-primary">{p.cta_bottone}</a>
    </div>
  </section>

  <!-- SCHEDE PROPRIETARI -->
  <section class="section proprietari-section">
    <div class="container">
      <div class="proprietari-grid">
        {p.proprietari.map((persona) => (
          <div class="persona-card">
            <div class="persona-body">
              <span class="eyebrow" style="text-align:left">{persona.ruolo}</span>
              <h3 class="persona-nome">{persona.nome}</h3>
              <div class="divider" style="margin-left:0; margin-right:auto;"></div>
              <!--<p class="persona-bio">{persona.bio}</p> -->
              <a href={persona.contatto_href} class="btn btn-outline" style="margin-top:1.5rem; display:inline-block;">
                {persona.contatto_label}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  

</Layout>
